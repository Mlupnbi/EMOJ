<Project Sdk="Microsoft.NET.Sdk">

	<!-- Import tModLoader mod properties -->
	<Import Project="..\tModLoader.targets" />

	<!-- General??? build.txt ?� version ????€?????????????????? 1.0.0 -->
	<PropertyGroup>
		<Version>0.5.14</Version>
		<AssemblyVersion>0.5.14.0</AssemblyVersion>
		<FileVersion>0.5.14.0</FileVersion>
		<!-- 允许 BuildMod=false 时仍能 dotnet build（游戏占用 .tmod 时仅编译 DLL） -->
		<TargetFramework>net8.0</TargetFramework>
		<LangVersion>12.0</LangVersion>
	</PropertyGroup>

	<!-- TinyPinyin ???????????????????????? TinyPinyin.dll ??? JIT ?????? client.log?� -->
	<ItemGroup>
		<EmbeddedResource Include="lib\TinyPinyin.dll">
			<LogicalName>TinyPinyinSatellite.dll</LogicalName>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<None Include="build.txt" />
		<None Include="icon.png" />
		<None Include="icon_small.png" />
		<None Include="description.txt" />
		<None Include="Localization\**\*.hjson" />
		<None Include="Data\BuffModSupport\**\*" CopyToOutputDirectory="PreserveNewest" />
		<None Include="Data\wiki_furniture_cache.json" CopyToOutputDirectory="PreserveNewest" />
		<None Include="Data\Blueprint\Templates\**\*" CopyToOutputDirectory="PreserveNewest" />
		<None Include="Data\Blueprint\Sources\improvegame\*.png" CopyToOutputDirectory="PreserveNewest" />
		<None Include="Scripts\EojUiAssets-README.md" />
		<None Remove="Assets\**\*.md" />
		<!-- ???????? ModSources????????????? tmod ? -->
		<None Remove="Data\BuffModSupport\decompiled_cache\**\*" />
	</ItemGroup>

	<!-- 与 build.txt buildIgnore 同步：游戏内 ModCompile 不读 csproj 的 Compile Remove -->
	<ItemGroup>
		<Compile Remove="Data\BuffModSupport\decompiled_cache\**\*.cs" />
		<Compile Remove="_tools\**\*.cs" />
	</ItemGroup>

	<!-- References -->

</Project>
